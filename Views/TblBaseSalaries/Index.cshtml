@model IEnumerable<PMS.Models.TblBaseSalary>

@{
    ViewData["Title"] = "DANH MỤC MỨC LƯƠNG CƠ SỞ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive mt-2">
                    <table id="myTable" class="table table-bordered table-striped">
                        <thead>
                            <tr class="text-center">
                                <th class ="text-center" style="width: 50px;">#</th>
                                <th class="text-center">Tên mức lương</th>
                                <th class="text-center" style="width: 120px;">Mức lương (VNĐ)</th>
                                <th class="text-center">Ngày hiệu lực</th>
                                <th class="text-center" style="width: 250px!important;">Mô tả</th>
                                <th class="text-center" style="width: 100px;">Trạng thái</th>
                                <th style="width: 60px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null)
                            {
                                int i = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class = "text-center">@(i++)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                                        <td class="text-right">@string.Format("{0:N0}", item.Value)</td>
                                        <td class="text-center">@item.DateIssued.ToString("dd/MM/yyyy")</td>
                                        <td title="@item.Description">
                                            @(item.Description?.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                                        </td>
                                        <td class="text-center">
                                            @if (item.Status == 1)
                                            {
                                                <i class="fa text-success">Hiệu lực</i>
                                            }
                                            else
                                            {
                                                <i class="fa text-danger">Hết hiệu lực</i>
                                            }
                                        </td>
                                        <td class="text-nowrap text-center">
                                        @if (item.Status != 0)
                                        {
                                            <a href="@Url.Action("Edit", new { id = item.Id })" data-toggle="tooltip" data-original-title="Sửa">
                                                <i class="fa fa-pencil text-inverse m-r-10"></i>
                                            </a>
                                        }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="~/assets/node_modules/datatables/jquery.dataTables.min.js"></script>
<script>
    $(document).ready(function () {
        $('#myTable').DataTable({
            "pageLength": 10,
            "ordering": true,
            "searching": true,
            "lengthChange": true,

            // DOM với 3 phần cùng hàng
            "dom":
                '<"d-flex justify-content-between align-items-center mb-3"<"d-flex align-items-center"l><"d-flex align-items-center"f>>' +
                '<"row"<"col-sm-12"tr>>' +
                '<"row"<"col-sm-5"i><"col-sm-7"p>>',

            "language": {
                "lengthMenu": "Hiển thị _MENU_ bản ghi",
                "search": "Tìm kiếm:"
            },

            "initComplete": function () {
                // 1. Lấy container bên trái (chứa "Hiển thị")
                var leftContainer = $('.dataTables_wrapper .d-flex.align-items-center').first();

                // 2. Thêm nút "Thêm mới" vào container bên trái
                var addButton = '<a class="btn btn-sm btn-primary ms-5" href="@Url.Action("Create")">Thêm mới</a>';
                leftContainer.append(addButton);

                // 3. Điều chỉnh khoảng cách
                leftContainer.css('gap', '20px');

                // 4. Điều chỉnh label
                $('.dataTables_length label, .dataTables_filter label').css({
                    'margin-bottom': '0',
                    'margin-right': '8px'
                });
            }
        });
    });
</script>

<style>
    .dataTables_wrapper .d-flex.justify-content-between {
        flex-wrap: nowrap;
        justify-content: flex-start !important; /* Thay space-between */
        gap: 80px; /* Khoảng cách cố định 20px */
    }

</style>