@model PMS.Models.TblMealAllowanceQuota

@{
    ViewData["Title"] = "Chi tiết định mức ăn ca";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Chi tiết định mức ăn ca</h4>
                    <hr />
                    
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Tên loại:</div>
                                <div class="form-control-plaintext">@Model.TypeName</div>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Số thứ tự:</div>
                                <div class="form-control-plaintext">@(Model.OrderNumber?.ToString() ?? "-")</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Giá trị loại:</div>
                                <div class="form-control-plaintext text-right">@Model.TypeValue.ToString()</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Mô tả:</div>
                                <div class="form-control-plaintext">@(Model.Description ?? "-")</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Ngày bắt đầu:</div>
                                <div class="form-control-plaintext">@(Model.StartDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Ngày kết thúc:</div>
                                <div class="form-control-plaintext">@(Model.EndDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-sm-12">
                            <div class="form-group mb-3">
                                <div class="boldText">Trạng thái:</div>
                                <div class="form-control-plaintext">
                                    @if (Model.Status == 1)
                                    {
                                        <span class="text-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">Hết hiệu lực</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
                            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
