@model PMS.Models.TblMealAllowanceQuota

@{
    ViewData["Title"] = "Chỉnh sửa định mức ăn ca";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tbl-position-forms.css">
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Edit" method="post" id="editForm">
                        <input type="hidden" asp-for="Id" />
                        
                        
                        <!-- Row 1: Tên loại, Giá trị loại, Số thứ tự (cùng 1 dòng) -->
                        <div class="row">
                            <div class="col-lg-3 col-md-4 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Tên loại:<code>*</code></div>
                                    <input asp-for="TypeName" class="form-control" placeholder="Nhập tên loại" required />
                                    <span asp-validation-for="TypeName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6 col-md-4 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Giá trị loại:<code>*</code></div>
                                    <!-- Visible formatted input -->
                                    <input type="text" 
                                           id="TypeValue_Display" 
                                           class="form-control" 
                                           placeholder="Nhập giá trị số nguyên" 
                                           data-number-format="true" 
                                           data-target="TypeValue"
                                           value="@Model.TypeValue"/>
                                    <!-- Hidden input for actual form submission -->
                                    @Html.HiddenFor(model => model.TypeValue)
                                    <span asp-validation-for="TypeValue" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-4 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Số thứ tự:</div>
                                    <input asp-for="OrderNumber" class="form-control" type="number" min="1" placeholder="Nhập STT" />
                                    <span asp-validation-for="OrderNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Row 3: Mô tả -->
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Mô tả:</div>
                                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết về định mức này"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Row 4: Ngày bắt đầu và Ngày kết thúc -->
                        <div class="row">
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Ngày bắt đầu:</div>
                                    <input asp-for="StartDate" class="form-control" type="date" />
                                    <span asp-validation-for="StartDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <div class="form-group mb-3">
                                    <div class="boldText">Ngày kết thúc:</div>
                                    <input asp-for="EndDate" class="form-control" type="date" />
                                    <span asp-validation-for="EndDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Buttons -->
                        <button type="submit" class="btn btn-success waves-effect waves-light m-r-10">Ghi dữ liệu</button>
                        <a asp-action="Index">Quay lại</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/number-formatter.js"></script>
    <script>
        $(document).ready(function () {
            // Form submit handler to ensure hidden input is synced
            $('#editForm').on('submit', function(e) {
                var displayInput = $('#TypeValue_Display');
                var hiddenInput = $('#TypeValue');
                
                if (displayInput.val()) {
                    var rawValue = displayInput.val().replace(/,/g, '');
                    hiddenInput.val(rawValue);
                    
                    console.log('TypeValue Display:', displayInput.val());
                    console.log('TypeValue Hidden:', hiddenInput.val());
                }
                
                if (!hiddenInput.val() || hiddenInput.val() === '0') {
                    alert('Vui lòng nhập giá trị loại!');
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
