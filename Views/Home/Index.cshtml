    </div>

    @{ 
        // Single boolean check (uses ViewBag if set by controller, otherwise checks Model.UserInfo roles)
        var showQuick = (ViewBag.ShowQuickAccess as bool?) ?? (Model?.UserInfo?.TblUserRoles?.Any(ur => ur.RoleId == 1) ?? false);
    }
    @if (showQuick)
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card chart-card">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-bolt me-2 text-warning"></i>Truy cập nhanh
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 justify-content-center">
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "TimeKeeping")" class="shortcut-btn btn btn-outline-primary">
                                        <i class="fas fa-clock text-primary"></i>
                                        <span>Chấm công</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "SourceAllocation")" class="shortcut-btn btn btn-outline-success">
                                        <i class="fas fa-wallet text-success"></i>
                                        <span>Phân nguồn</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "LeaveManagement")" class="shortcut-btn btn btn-outline-info">
                                        <i class="fas fa-calendar-minus text-info"></i>
                                        <span>Nghỉ phép</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "TblUsers")" class="shortcut-btn btn btn-outline-warning">
                                        <i class="fas fa-users text-warning"></i>
                                        <span>Nhân viên</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "TblDepartments")" class="shortcut-btn btn btn-outline-secondary">
                                        <i class="fas fa-building text-secondary"></i>
                                        <span>Phòng ban</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "SalarySettlement")" class="shortcut-btn btn btn-outline-danger">
                                        <i class="fas fa-file-invoice-dollar text-danger"></i>
                                        <span>Quyết toán</span>
                                    </a>
                                </div>
                                <div class="col-auto">
                                    <a href="@Url.Action("Index", "WorkPerformance")" class="shortcut-btn btn btn-outline-dark">
                                        <i class="fas fa-chart-line text-dark"></i>
                                        <span>Hiệu suất</span>
                                    </a>
                                </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script type="text/javascript">
    google.charts.load('current', { 'packages': ['corechart', 'bar'] });
    google.charts.setOnLoadCallback(drawCharts);

    function drawCharts() {
        drawDepartmentChart();
        drawBudgetChart();
    }

    function drawDepartmentChart() {
        var data = google.visualization.arrayToDataTable([
            ['Phòng ban', 'Số nhân viên', { role: 'style' }]
            @if (Model.DepartmentStats != null)
            {
                @foreach (var dept in Model.DepartmentStats)
                {
                    <text>, ['@Html.Raw(dept.DepartmentName)', @dept.EmployeeCount, '@dept.Color']</text>
                }
            }
        ]);

        var options = {
            title: '',
            legend: { position: 'none' },
            hAxis: {
                textStyle: { fontSize: 11, fontName: 'Be Vietnam Pro' }
            },
            vAxis: {
                minValue: 0,
                textStyle: { fontSize: 11, fontName: 'Be Vietnam Pro' }
            },
            chartArea: { left: 50, top: 20, width: '85%', height: '75%' },
            bar: { groupWidth: '60%' },
            animation: { startup: true, duration: 1000, easing: 'out' }
        };

        var chart = new google.visualization.ColumnChart(document.getElementById('departmentChart'));
        chart.draw(data, options);
    }

    function drawBudgetChart() {
        var data = google.visualization.arrayToDataTable([
            ['Quý', 'Ngân sách']
            @if (Model.BudgetByQuarter != null && Model.BudgetByQuarter.Any())
            {
                @foreach (var item in Model.BudgetByQuarter)
                {
                    <text>, ['@Html.Raw(item.Label)', @item.Value]</text>
                }
            }
            else
            {
                <text>, ['Quý 1', 0], ['Quý 2', 0], ['Quý 3', 0], ['Quý 4', 0]</text>
            }
        ]);

        var options = {
            title: '',
            pieHole: 0.4,
            colors: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e'],
            legend: {
                position: 'right',
                textStyle: { fontSize: 12, fontName: 'Be Vietnam Pro' }
            },
            chartArea: { left: 20, top: 20, width: '90%', height: '90%' },
            pieSliceText: 'value',
            pieSliceTextStyle: { fontSize: 11 },
            animation: { startup: true, duration: 1000, easing: 'out' }
        };

        var chart = new google.visualization.PieChart(document.getElementById('budgetChart'));
        chart.draw(data, options);
    }

    // Responsive charts
    $(window).resize(function() {
        drawCharts();
    });
</script>