@model IEnumerable<PMS.Models.TblPhuTros>
@{
    var users = ViewBag.Users as List<PMS.Models.TblUser> ?? new List<PMS.Models.TblUser>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/handsontable@14.3.0/dist/handsontable.full.min.css" />
<style>
    /* Tăng font-size và màu chữ */
    .handsontable td {
        color: #333333 !important;
        font-size: 14px !important;
        white-space: nowrap !important;
    }
    .handsontable span.colHeader {
        color: #333333 !important;
        font-weight: 700 !important;
    }
    /* Ẩn scrollbar dọc, giữ scrollbar ngang */
    #cdPhiTable .wtHolder {
        overflow-x: auto !important;
        overflow-y: visible !important;
        height: auto !important;
    }
    #cdPhiTable .ht_master .wtHolder {
        overflow-x: auto !important;
        overflow-y: visible !important;
    }
    #cdPhiTable .ht_clone_top .wtHolder {
        overflow: hidden !important;
    }
</style>
<div id="cdPhiTableWrapper" style="overflow:visible;">
    <div id="cdPhiTable"></div>

    <script>
        (function () {
            const container = document.getElementById('cdPhiTable');

            // Dữ liệu từ server
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Select((x, i) => new
                {
            STT = i + 1,
            TenNhanVien = x.TenNhanVien,
            MaNhanVien = x.MaNhanVien,
            // TenPhongBan = x.TenPhongBan,
            SoTaiKhoan = x.SoTaiKhoan ?? "Chưa có",
            HeSoLuong = x.HeSoLuong,
            ThuDFCD = x.ThuDFCD,
            QuyTuongTroXH = x.QuyTuongTroXH,
            TongCong = x.TongCong,
            UserId = users.FirstOrDefault(u => u.UserCode == x.MaNhanVien)?.Id ?? 0
                })
                ));

            const nestedHeaders = [
                ['STT', 'Tên nhân viên', 'Mã Nhân viên', 'Số tài khoản', 'Hệ số lương', 'Thu ĐF CĐ', 'Quỹ tương trợ XH', 'Tổng cộng']            ];

            const columns = [
                { data: 'STT', type: 'numeric', readOnly: true, width: 50, className: 'htCenter' },
                { data: 'TenNhanVien', type: 'text', readOnly: true, width: 160 },
                { data: 'MaNhanVien', type: 'text', readOnly: true, width: 100 },
                
                { data: 'SoTaiKhoan', type: 'text', readOnly: true, width: 120 },
                { data: 'HeSoLuong', type: 'numeric', numericFormat: { pattern: '0.00' }, readOnly: true, width: 100 },
                { data: 'ThuDFCD', type: 'numeric', numericFormat: { pattern: '0,0' }, width: 120 },
                { data: 'QuyTuongTroXH', type: 'numeric', numericFormat: { pattern: '0,0' }, width: 120 },
                { data: 'TongCong', type: 'numeric', numericFormat: { pattern: '0,0' }, readOnly: true, width: 120 }
            ];

            let isCalculating = false;

            // Hàm tính Tổng cộng
            function calculateTongCong(row) {
                const thuDFCD = parseFloat(hot.getDataAtRowProp(row, 'ThuDFCD')) || 0;
                const quyTuongTroXH = parseFloat(hot.getDataAtRowProp(row, 'QuyTuongTroXH')) || 0;
                return thuDFCD + quyTuongTroXH;
            }

            function updateCalculatedColumns(row) {
                if (isCalculating) return;
                isCalculating = true;

                const tongCong = calculateTongCong(row);
                hot.setDataAtRowProp(row, 'TongCong', tongCong, 'calculation');

                isCalculating = false;
            }

            const hot = new Handsontable(container, {
                data: data,
                columns: columns,
                nestedHeaders: nestedHeaders,
                rowHeaders: false,
                colHeaders: false,
                stretchH: 'all',
                height: 'auto',  // Sử dụng scroll dọc của web
                autoColumnSize: true,
                manualColumnMove: true,
                filters: false,
                dropdownMenu: false,
                contextMenu: true,
                licenseKey: 'non-commercial-and-evaluation',

                afterChange: function (changes, source) {
                    if (!changes || source === 'loadData' || source === 'calculation') return;

                    changes.forEach(([row, prop, oldVal, newVal]) => {
                        const rowData = hot.getSourceDataAtRow(row);
                        const userId = rowData.UserId;
                        const month = parseInt($('#selectMonth').val());
                        const year = parseInt($('#selectYear').val());

                        // Nếu thay đổi ThuDFCD hoặc QuyTuongTroXH thì tính lại Tổng cộng
                        if ((prop === 'ThuDFCD' || prop === 'QuyTuongTroXH') && oldVal !== newVal) {
                            updateCalculatedColumns(row);
                        }

                        if (userId > 0) {
                            // Cập nhật ThuDFCD
                            if (prop === 'ThuDFCD' && oldVal !== newVal) {
                                $.ajax({
                                    url: '/PhuTro/UpdateUnionFeeIncome',
                                    type: 'POST',
                                    contentType: 'application/json',
                                    data: JSON.stringify({
                                        UserId: userId,
                                        Month: month,
                                        Year: year,
                                        UnionFeeIncome: parseFloat(newVal) || 0
                                    })
                                });
                            }

                            // Cập nhật Quỹ tương trợ XH
                            if (prop === 'QuyTuongTroXH' && oldVal !== newVal) {
                                $.ajax({
                                    url: '/PhuTro/UpdateSocialWelfareFund',
                                    type: 'POST',
                                    contentType: 'application/json',
                                    data: JSON.stringify({
                                        UserId: userId,
                                        Month: month,
                                        Year: year,
                                        SocialWelfareFund: parseFloat(newVal) || 0
                                    })
                                });
                            }
                        }
                    });
                }
            });

            // Lưu toàn bộ
            $('#btnSaveCDPhi').click(function () {
                const month = parseInt($('#selectMonth').val());
                const year = parseInt($('#selectYear').val());

                if (!month || !year) {
                    alert('Vui lòng chọn tháng và năm trước khi lưu!');
                    return;
                }

                const sourceData = hot.getSourceData();
                const saveData = [];

                sourceData.forEach((row) => {
                    if (row.UserId > 0) {
                        saveData.push({
                            UserId: row.UserId,
                            UnionFeeIncome: parseFloat(row.ThuDFCD) || 0,
                            SocialWelfareFund: parseFloat(row.QuyTuongTroXH) || 0
                        });
                    }
                });

                $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Đang lưu...');

                $.ajax({
                    url: '/PhuTro/SavePhuTroCDPhi',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        Month: month,
                        Year: year,
                        Data: saveData
                    }),
                    success: function (response) {
                        if (response.success) {
                            alert('Lưu thành công: ' + response.message);
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('Lỗi khi lưu dữ liệu: ' + error);
                    },
                    complete: function () {
                        $('#btnSaveCDPhi').prop('disabled', false).html('<i class="fas fa-save me-1"></i>Lưu dữ liệu');
                    }
                });
            });

            function calculateHotHeight() {
                const windowHeight = window.innerHeight;
                const offset = 360;
                return Math.max(windowHeight - offset, 400);
            }



            // ===== HIỂN THỊ CÔNG THỨC TRONG SEARCH-BOX =====
            HandsontableFormula.init(hot, 'formulaInput', {
                getFormula: function(row, col, value, hotInstance) {
                    const colHeader = hotInstance.getColHeader(col);
                    if (col === 5) {
                        return `= Thu ĐF CĐ`;
                    } else if (col === 6) {
                        return `= Quỹ tương trợ XH`;
                    } else if (col === 7) {
                        return `= Thu ĐF CĐ + Quỹ tương trợ XH`;
                    }
                    return `${value}`;
                },
                shouldShow: function(row, col, value) {
                    return value != null && value !== '';
                }
            });
        })();
    </script>
</div>
