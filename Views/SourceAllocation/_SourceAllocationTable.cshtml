@model IEnumerable<PMS.Models.TblSoureAllocation>

<div class="table-responsive">
    <table class="table table-striped table-bordered" id="myTable">
        <thead>
            <tr>
                <th>STT</th>
                <th>Kế hoạch ngân sách</th>
                <th>Quý</th>
                <th>Tháng</th>
                <th>Số tiền phân bổ</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var stt = 1;
                foreach (var item in Model)
                {
                    // KIỂM TRA TỪNG ITEM VÀ CÁC PROPERTY QUAN TRỌNG
                    if (item != null)
                    {
                        <tr>
                            <td>@stt</td>
                            <td>@(item.BudgetPlanId.ToString() ?? "N/A")</td>
                            <td>Quý @item.Quarter</td>
                            <td>Tháng @(item.MonthNumber.ToString() ?? "N/A")</td>
                            <td>@((item.BudgetPlan.TotalBudget).ToString("N0"))</td>
                            <td>
                                @if (item.status == 1)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Không hoạt động</span>
                                }
                            </td>
                            <td>
                                @if (item.Id > 0)
                                {
                                    <a class="btn btn-sm btn-primary" href="@Url.Action("Edit", new { id = item.Id })">Sửa</a>
                                    <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = item.Id })">Xóa</a>
                                }
                            </td>
                        </tr>
                        stt++;
                    }
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        <i class="fa fa-info-circle"></i> Không có dữ liệu để hiển thị
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>