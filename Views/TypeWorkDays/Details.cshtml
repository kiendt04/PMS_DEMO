@model PMS.Models.TblTypeWorkDays

@{
    ViewData["Title"] = "Chi tiết loại ngày công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="card-title mb-0">Chi tiết loại ngày công</h4>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                            <i class="fa fa-edit"></i> Chỉnh sửa
                        </a>
                    </div>
                </div>
                <hr />
                
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Tên loại ngày công:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                            
                            <dt class="col-sm-4">Ký hiệu công:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.PerformanceSign)</dd>
                            
                            <dt class="col-sm-4">Ký hiệu ngày:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.DaysSign)</dd>
                            
                            <dt class="col-sm-4">Ngày bắt đầu:</dt>
                            <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</dd>
                            
                            <dt class="col-sm-4">Ngày kết thúc:</dt>
                            <dd class="col-sm-8">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd/MM/yyyy") : "")</dd>
                            
                            <dt class="col-sm-4">Trạng thái:</dt>
                            <dd class="col-sm-8">
                                @if (Model.Status == 0)
                                {
                                    <span class="badge badge-danger">Ngưng hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge badge-success">Hoạt động</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Giá trị:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Value)</dd>
                            
                            <dt class="col-sm-4">Thứ tự:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Order)</dd>
                            
                            <dt class="col-sm-4">Ghi chú:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Note)</dd>
                            
                            <dt class="col-sm-4">Người tạo:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.CreatedUser)</dd>
                            
                            <dt class="col-sm-4">Ngày tạo:</dt>
                            <dd class="col-sm-8">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</dd>
                            
                            <dt class="col-sm-4">Người sửa:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.ModifiedUser)</dd>
                            
                            <dt class="col-sm-4">Ngày sửa:</dt>
                            <dd class="col-sm-8">@Model.ModifiedDate.ToString("dd/MM/yyyy HH:mm")</dd>
                        </dl>
                    </div>
                </div>
                
                <div class="mt-3">
                     @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn btn-secondary" })
                </div>
            </div>
        </div>
    </div>
</div>
